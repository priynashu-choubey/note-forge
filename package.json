{
  "name": "noteforge",
  "version": "1.0.0",
  "private": true,
  "description": "Offline-first note editor with Excalidraw, microservices backend",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev:services": "npm run dev:api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
