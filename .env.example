# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── JWT Secrets (CHANGE THESE IN PRODUCTION) ────────────────────────────────
JWT_ACCESS_SECRET=noteforge-access-secret-change-in-prod
JWT_REFRESH_SECRET=noteforge-refresh-secret-change-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the frontend (Vite dev server or deployed URL)
CORS_ORIGIN=http://localhost:5173
